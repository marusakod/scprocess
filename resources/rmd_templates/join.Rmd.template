```{r setup_knitr, include=FALSE}
library('BiocStyle')
knitr::opts_chunk$set( autodep=TRUE, cache=TRUE, cache.lazy=FALSE, dev='png',
  fig.path = "figure/${join_tag}.Rmd/", message = FALSE, warning = FALSE)
knitr::opts_knit$set(root.dir = '..', base.dir = '../public/', base.url = '')
# workflowr::wflow_build(files='analysis/${join_tag}.Rmd', view=F, verbose=T, delete_cache=F)
```


```{r setup_helpers, cache=FALSE, include=FALSE}
scprocess_dir = "${scprocess_dir}"
source(file.path(scprocess_dir, 'scripts/utils.R'))
source(file.path(scprocess_dir, 'scripts/integration.R'))
source(file.path(scprocess_dir, 'scripts/marker_genes.R'))
source(file.path(scprocess_dir, 'scripts/fgsea.R'))
library(stringi)
setDTthreads(1L)
```


```{r setup_input, include=FALSE}
join_name     = "${join_name}"
join_tag      = "${join_tag}"
join_int_dir  = "${join_int_dir}"
join_mkr_dir  = "${join_mkr_dir}"
ref_txome     = "${ref_txome}"
sel_res       = "${mkr_sel_res}"
res_ls        = "${int_res_ls}" %>% str_split(pattern = ' ') %>% unlist() %>% as.numeric()

not_ok_re     = "(lincRNA|lncRNA|pseudogene|antisense)"
min_cpm_mkr   = 50
min_cells     = 10
gsea_cut      = 0.1
gsea_var_sel  = "z_score"

# input file paths
integration_f = list.files(join_int_dir, pattern = "^integrated_dt_.*\\.csv\\.gz$", full.names = TRUE)[1]
sample_meta_f = list.files(join_int_dir, pattern = "^joint_sample_meta_.*\\.csv$",  full.names = TRUE)[1]
mkrs_f        = list.files(join_mkr_dir, pattern = "^pb_marker_genes_.*\\.csv\\.gz$", full.names = TRUE)[1]
pb_hvgs_f     = list.files(join_mkr_dir, pattern = "^pb_hvgs_.*\\.csv\\.gz$",        full.names = TRUE)[1]
pb_f          = list.files(join_mkr_dir, pattern = "^pb_.*\\.rds$",                  full.names = TRUE)[1]
fgsea_go_bp_f = list.files(join_mkr_dir, pattern = "go_bp",  full.names = TRUE)[1]
fgsea_go_cc_f = list.files(join_mkr_dir, pattern = "go_cc",  full.names = TRUE)[1]
fgsea_go_mf_f = list.files(join_mkr_dir, pattern = "go_mf",  full.names = TRUE)[1]

do_gsea = ref_txome %in% c('human_2024', 'human_2020', 'mouse_2024', 'mouse_2020')
```


```{r load_integration, include=FALSE}
int_all = fread(integration_f)
int_dt  = int_all[ !is.na(UMAP1) ] %>%
  .[, c("sample_id", "cell_id", "embedding", "UMAP1", "UMAP2",
    str_subset(names(int_all), "RNA_snn_res")), with = FALSE]
```


```{r load_metadata, include=FALSE}
meta_dt = fread(sample_meta_f)

# join project_id (and any other metadata) from sample meta into int_dt
# project_id may not be in integrated_dt if batch_var was only sample_id
meta_key = meta_dt[, .(sample_id, project_id)] %>% unique
int_dt   = merge(int_dt, meta_key, by = "sample_id")
```


```{r setup_sel_res, include=FALSE}
sel_cl_int_dt = copy(int_dt) %>%
  .[, cluster := get(paste0("RNA_snn_res.", sel_res))] %>%
  .[, .(sample_id, project_id, cell_id, UMAP1, UMAP2, cluster)] %>%
  merge(meta_dt, by = "sample_id", suffixes = c("", ".y")) %>%
  .[, grep("\\.y$", names(.), value = TRUE) := NULL]

cl_ord = levels(fct_infreq(sel_cl_int_dt$cluster))

metadata_vars = setdiff(names(meta_dt), c("sample_id", "project_id", "bad_sample_id"))
cfg_metadata_vars = "${metadata_vars}" %>% str_split(" ") %>% unlist() %>% trimws()
if (!all(cfg_metadata_vars == ""))
  metadata_vars = intersect(cfg_metadata_vars, metadata_vars)
do_metadata   = length(metadata_vars) > 0
```


```{r load_gene_biotypes, include=FALSE}
sel_ref_txome = ref_txome
idx_params  = Sys.getenv('SCPROCESS_DATA_DIR') %>%
  file.path('index_parameters.csv') %>% fread
gtf_dt_f    = idx_params[ref_txome == sel_ref_txome, gtf_txt_f][1]
biotypes_dt = load_gene_biotypes(gtf_dt_f)
```


```{r load_cpms, include=FALSE}
cpms_dt = readRDS(pb_f) %>%
  make_logcpms_all("sample_id", lib_size_method = "edger",
    min_cells = min_cells, n_cores = 1L) %>%
  merge(biotypes_dt[, .(gene_id, gene_type)], by = "gene_id")
```


```{r load_hvgs, include=FALSE}
pb_hvgs_dt = fread(pb_hvgs_f) %>%
  .[ str_detect(gene_type, not_ok_re, negate = TRUE) ] %>%
  .[ order(-vst_var) ]
top_hvgs = pb_hvgs_dt[ 1:50 ] %>% .[, geneset := "HVGs"]
```


```{r load_markers, include=FALSE}
mkrs_dt = fread(mkrs_f)
if (is.null(cl_ord))
  cl_ord = sort(unique(mkrs_dt$cluster))
mkrs_ls = list(HVGs = top_hvgs)
```


```{r get_top_markers, include=FALSE}
top_min_dt = mkrs_dt[ str_detect(gene_type, not_ok_re, negate = TRUE) ] %>%
  .[ logcpm.sel >= log(min_cpm_mkr + 1) ] %>%
  get_top_markers
```


```{r load_gsea, include=FALSE}
fgsea_fs = c(fgsea_go_bp_f, fgsea_go_cc_f, fgsea_go_mf_f) %>%
  setNames(c("go_bp", "go_cc", "go_mf"))
gsea_ls = lapply(fgsea_fs, function(f) if (!is.na(f) && file.exists(f)) fread(f) else NULL)
```


## Integration diagnostics{.tabset}

Cells from all projects were integrated using Harmony batch correction. Clustering
was performed at multiple resolution values.

```{r plot_clusters, fig.height=7, fig.width=9, results="asis"}
for (res in res_ls) {
  cat('### ', res, '\n')
  g_cl   = plot_umap_cluster(
    umap_dt  = int_dt[, .(cell_id, UMAP1, UMAP2)],
    clust_dt = int_dt[, .(cell_id, cluster = get(paste0('RNA_snn_res.', res)))],
    name     = sprintf('res = %s', res))
  g_dens = plot_umap_density(int_dt[, .(cell_id, UMAP1, UMAP2)])
  print(g_cl + g_dens)
  cat('\n\n')
}
```


## Project composition

These plots show how cells from each project are distributed across the UMAP and
across clusters. Even mixing across projects is the primary indicator that Harmony
integration was successful.

### Project distribution over UMAP

```{r plot_project_umap, fig.height=5, fig.width=8}
print(plot_clusters_annotated_by_densities(int_dt, 'project_id'))
```

### Project proportions per cluster

Proportion of cells from each project within each cluster at resolution `r sel_res`.

```{r plot_project_per_cluster, fig.height=5, fig.width=8}
print(plot_clusters_by_metadata(meta_dt, sel_cl_int_dt, meta_vars = 'project_id', cl_order = cl_ord))
```


## Cluster distribution across samples{.tabset}

This plot shows the entropy of cluster membership across samples. High entropy indicates
cells from many samples are evenly distributed within a cluster; low entropy indicates a
cluster is dominated by one or few samples.

```{r plot_entropy_samples, fig.height=5, fig.width=7, results="asis"}
n_clusts = res_ls %>% lapply(function(res) {
  length(unique(int_dt[[paste0('RNA_snn_res.', res)]]))
})
res_ls_pl = res_ls[n_clusts > 1]
for (res in res_ls_pl) {
  cat('### ', res, '\n')
  input_dt = int_dt[, .(batch_var = sample_id, cell_id,
    cluster = get(paste0('RNA_snn_res.', res)))]
  suppressWarnings(print(plot_cluster_entropies(input_dt, 'batch_var', what = "norm")))
  cat('\n\n')
}
```


## Cluster distribution across projects{.tabset}

The same entropy metric applied across projects rather than samples.

```{r plot_entropy_projects, fig.height=5, fig.width=7, results="asis"}
for (res in res_ls_pl) {
  cat('### ', res, '\n')
  input_dt = int_dt[, .(batch_var = project_id, cell_id,
    cluster = get(paste0('RNA_snn_res.', res)))]
  suppressWarnings(print(plot_cluster_entropies(input_dt, 'batch_var', what = "norm")))
  cat('\n\n')
}
```


